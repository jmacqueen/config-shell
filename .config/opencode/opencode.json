{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "share": "disabled",
  "autoupdate": false,
  "lsp": true,
  "model": "github-copilot/gpt-5.4",
  "instructions": ["~/.config/opencode/AGENTS-local.md"],
  "provider": {
    "bs-ai-mcl": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Bitsight AI Gateway",
      "options": {
        "baseURL": "{env:BS_LLM_API_BASE_DEV}",
        "apiKey": "{env:BS_LLM_API_KEY_DEV}"
      },
      "models": {
        "anthropic.claude-haiku-4-5-20251001-v1:0": {
          "name": "Claude Haiku 4.5"
        },
        "us.anthropic.claude-sonnet-4-5-20250929-v1:0": {
          "name": "Claude Sonnet 4.5"
        },
        "anthropic.claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "anthropic.claude-opus-4-6-v1": {
          "name": "Claude Opus 4.6"
        },
        "gpt-5.5": {
          "name": "GPT-5.5",
          "provider": {
            "npm": "@ai-sdk/openai"
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "provider": {
            "npm": "@ai-sdk/openai"
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
          "provider": {
            "npm": "@ai-sdk/openai"
          }
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT-5.1 Codex Mini",
          "provider": {
            "npm": "@ai-sdk/openai"
          }
        },
        "gemini-2.5-pro": {
          "name": "gemini-2.5-pro"
        },
        "gemini-3-pro-preview": {
          "name": "gemini-3-pro-preview"
        }
      }
    },
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "omlx",
      "blacklist": ["MarkItDown"],
      "options": {
        "baseURL": "http://127.0.0.1:9999/v1",
        "apiKey": "{env:OMLX_API_KEY}",
        "probe": "omlx"
      },
      "models": {
        "Qwen3-Coder-Next-MLX-4bit": {
          "name": "Qwen3-Coder-Next-MLX-4bit"
        },
        "MarkItDown": {
          "name": "MarkItDown",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  },
  "agent": {
    "plan": {
      "model": "bs-ai-mcl/anthropic.claude-opus-4-6-v1",
      "permission": {
        "edit": {
          "*": "ask",
          "*.md": "allow",
          "*.mdx": "allow",
          "*.txt": "allow"
        }
      }
    }
  },
  "plugin": ["opencode-model-scout"],
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": false
    },
    "searxng": {
      "type": "local",
      "environment": {
        "SEARXNG_URL": "http://localhost:8888/"
      },
      "command": ["mcp-searxng"],
      "enabled": false
    }
  }
}
